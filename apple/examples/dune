(subdir
 BonsaiNativeMacDemos.app
 (rule
  (alias default)
  (deps Contents/Info.plist Contents/MacOS/BonsaiNativeMacDemos)
  (enabled_if
   (= %{context_name} default))
  (action (progn)))
 (subdir
  Contents
  (rule
   (deps ../../Info.mac.plist)
   (targets Info.plist)
   (enabled_if
    (= %{context_name} default))
   (action
    (copy ../../Info.mac.plist Info.plist)))
  (subdir
   MacOS
   (rule
    (deps
     ../../../mac_app.exe
     ../../../../../scripts/apple-codesign-identity.sh)
    (targets BonsaiNativeMacDemos)
    (enabled_if
     (= %{context_name} default))
    (action
     (progn
      (copy ../../../mac_app.exe BonsaiNativeMacDemos)
      (run chmod u+w BonsaiNativeMacDemos)
      (run strip -x BonsaiNativeMacDemos)
      (run
       /bin/sh
       -c
       "codesign --force --sign \"$(%{dep:../../../../../scripts/apple-codesign-identity.sh})\" --timestamp=none BonsaiNativeMacDemos")))))))
